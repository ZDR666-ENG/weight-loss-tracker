generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  height        Float?
  weight        Float?
  age           Int?
  gender        String?
  goalWeight    Float?
  createdAt     DateTime       @default(now())
  weightLogs    WeightLog[]
  meals         Meal[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  exerciseLogs  ExerciseLog[]
  exercisePlans ExercisePlan[]
}

model WeightLog {
  id         String   @id @default(cuid())
  userId     String
  weight     Float
  recordedAt DateTime @default(now())
  note       String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meal {
  id       String   @id @default(cuid())
  userId   String
  name     String
  calories Float
  protein  Float    @default(0)
  carbs    Float    @default(0)
  fat      Float    @default(0)
  mealType String   @default("other")
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id     String @id @default(cuid())
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model ExerciseLog {
  id         String   @id @default(cuid())
  userId     String
  type       String
  duration   Int      // minutes
  calories   Float
  date       DateTime @default(now())
  note       String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExercisePlan {
  id         String @id @default(cuid())
  userId     String
  dayOfWeek  Int    // 0=Monday, 6=Sunday
  type       String
  duration   Int    // planned minutes
  calories   Float  // estimated calories
  note       String?
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
